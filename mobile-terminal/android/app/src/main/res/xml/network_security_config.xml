<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Backend en LAN usa HTTP (Socket.IO). Necesario en Android 9+. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
