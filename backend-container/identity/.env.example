# Puerto del servicio de identidad (3002 detrás del gateway; 3001 si se ejecuta solo)
PORT=3002
NODE_ENV=development
LOG_LEVEL=info

# MongoDB (misma base que el monolito durante la migración)
MONGO_URI=mongodb://localhost:27017/firewall_protocol
MONGO_DB_NAME=firewall_protocol
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# JWT (debe coincidir con game-realtime / monolito para validar tokens)
JWT_SECRET=change-me-in-production
SESSION_SECRET=
JWT_ACCESS_TTL_SEC=86400
JWT_REFRESH_TTL_DAYS=90

# URL pública del gateway — enlaces en correos (ngrok / dominio; NO localhost en móvil)
APP_PUBLIC_URL=https://tu-tunel.ngrok-free.dev
# Alternativa: NGROK_URL o GATEWAY_PUBLIC_URL
# URL interna del servicio media (eliminar avatares al borrar cuenta)
MEDIA_URL=http://media:3003

# SMTP (Gmail, SendGrid, Mailtrap, etc.)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Firewall Protocol <noreply@tudominio.com>"
