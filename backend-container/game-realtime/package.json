{
  "name": "@firewall/game-realtime-service",
  "version": "0.1.0",
  "private": true,
  "description": "Firewall Protocol — juego en tiempo real (Socket.IO + motor)",
  "main": "src/server.ts",
  "license": "MIT",
  "scripts": {
    "start": "node -r ts-node/register src/server.ts",
    "dev": "node -r ts-node/register src/server.ts",
    "build": "tsc",
    "start:prod": "node dist/server.js",
    "test:votes": "node -r ts-node/register src/game/voteResolution.test.ts",
    "test:victory": "node -r ts-node/register src/game/victoryChecker.test.ts",
    "test:join": "node -r ts-node/register src/game/roomJoin.test.ts",
    "test:chat": "node -r ts-node/register src/game/ChatManager.test.ts",
    "test:socket": "node -r ts-node/register src/utils/socketErrors.test.ts",
    "db:setup": "node -r ts-node/register scripts/setup-mongodb.ts",
    "db:seed": "node -r ts-node/register scripts/seed-roles.ts"
  },
  "dependencies": {
    "@firewall/identity-service": "file:../identity",
    "body-parser": "^1.20.2",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "mongodb": "^6.21.0",
    "socket.io": "^4.7.2",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.43",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
