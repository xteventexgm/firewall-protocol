{
  "name": "firewall-protocol-backend",
  "version": "0.1.0",
  "main": "src/server.ts",
  "license": "MIT",
  "scripts": {
    "start": "node -r ts-node/register src/server.ts",
    "dev": "node -r ts-node/register src/server.ts",
    "db:setup": "node -r ts-node/register scripts/setup-mongodb.ts",
    "db:migrate": "node -r ts-node/register scripts/migrate-json-to-mongodb.ts",
    "db:seed": "node -r ts-node/register scripts/seed-roles.ts",
    "test:votes": "node -r ts-node/register src/game/voteResolution.test.ts",
    "test:victory": "node -r ts-node/register src/game/victoryChecker.test.ts",
    "test:join": "node -r ts-node/register src/game/roomJoin.test.ts",
    "test:chat": "node -r ts-node/register src/game/ChatManager.test.ts",
    "test:socket": "node -r ts-node/register src/utils/socketErrors.test.ts",
    "test:database": "node -r ts-node/register src/services/MongoDBAdapter.test.ts",
    "test": "npm run test:votes && npm run test:join && npm run test:chat && npm run test:socket && npm run test:database",
    "qa:bot-match": "node -r ts-node/register scripts/run-bot-qa.ts"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "mongodb": "^6.21.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.43",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
