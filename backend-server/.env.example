# Docker (docker compose up) — copia a .env y completa los valores
# DOCKER=1 se inyecta automáticamente desde docker-compose.yml
# NODE_ENV=production
# PORT=3000
# MONGO_URI=mongodb+srv://...
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
# JWT_SECRET=
# AVATAR_STORAGE=r2
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=avatars
# S3_REGION=auto

# Entorno
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# MongoDB — obligatorio para auth de usuarios y persistencia en producción
# Atlas (reemplaza <db_password>):
# MONGO_URI=mongodb+srv://firewall-protocol_db_user:<db_password>@firewall-protocol.vzqx091.mongodb.net/?appName=Firewall-protocol
MONGO_URI=mongodb://localhost:27017/firewall_protocol
MONGO_DB_NAME=firewall_protocol

# Si mongodb+srv falla con querySrv ECONNREFUSED (router/DNS en Windows):
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# Sin MongoDB: deja MONGO_URI vacío y usa JSON en DATA_DIRECTORY
# MONGO_URI=

# Directorio JSON (solo si MONGO_URI está vacío)
DATA_DIRECTORY=

# Auth — requerido para /api/auth/* (registro, login, historial)
JWT_SECRET=cambia-este-secreto-en-produccion
SESSION_SECRET=

# JWT — access corto para API; refresh largo (móvil renueva al abrir / en 401)
# Access: 86400 = 24 h · Refresh: 90 días (se extiende en cada refresh exitoso)
JWT_ACCESS_TTL_SEC=86400
JWT_REFRESH_TTL_DAYS=90

# Opciones operacionales
AUTO_ADVANCE=
NIGHT_DURATION_MS=
DAY_DURATION_MS=

# Avatares — `disk` (local) o `r2` / `s3` (API S3-compatible: Cloudflare R2, etc.)
AVATAR_STORAGE=disk

# Cloudflare R2 (AVATAR_STORAGE=r2)
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY=          # R2 → Manage R2 API Tokens → Access Key ID
# S3_SECRET_KEY=          # Secret Access Key del token
# S3_BUCKET=avatars
# S3_REGION=auto

# Alias legacy (también aceptados): R2_ENDPOINT, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY, R2_BUCKET
# MinIO local (AVATAR_STORAGE=minio): MINIO_ENDPOINT, MINIO_PORT, MINIO_ACCESS_KEY, MINIO_SECRET_KEY
